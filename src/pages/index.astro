---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import FAQ from '../components/FAQ.astro';
import { faqs, problemsSolved, services, siteConfig } from '../data/site';
import { projects } from '../data/projects';
import { articles } from '../data/articles';
import { buildMeta } from '../utils/seo';
import { faqSchema, localBusinessSchema, professionalServiceSchema, serviceSchema, websiteSchema } from '../utils/schema';

const meta = buildMeta({
  title: 'Mohammed Rafique Kuwari | AI Automation, SEO & GEO Implementation',
  description:
    'Portfolio of Mohammed Rafique Kuwari in Bhiwandi, Maharashtra, India. Explore AI automation, workflow systems, document automation, RAG chatbots, and SEO / GEO implementation.',
  pathname: '/',
  keywords: [
    'AI automation and SEO implementation',
    'AI automation engineer in Bhiwandi',
    'RAG chatbot developer in Bhiwandi',
    'Workflow automation developer in Bhiwandi',
    'Document workflow automation in Bhiwandi',
    'SEO and GEO implementation'
  ]
});
---
<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  keywords={meta.keywords}
  schema={[websiteSchema, localBusinessSchema, serviceSchema, professionalServiceSchema, faqSchema(faqs)]}
>
  <section class="hero">
    <article class="card hero-copy reveal">
      <p class="kicker">AI automation, SEO &amp; GEO implementation in Bhiwandi, Maharashtra, India</p>
      <h1>{siteConfig.name}</h1>
      <h2 style="margin-top: 0.55rem;">{siteConfig.title}</h2>
      <p>
        I help businesses reduce manual work, automate workflows, improve Google and AI-search visibility, turn documents into
        usable structured data, and build RAG chat systems grounded in internal knowledge.
      </p>
      <p class="location">{siteConfig.location}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/projects">View Projects</a>
        <a class="btn btn-secondary" href="/contact">Contact Me</a>
      </div>
    </article>

    <aside class="card reveal">
      <h2>How I work</h2>
      <ul class="list">
        <li>Define business bottlenecks and measurable targets.</li>
        <li>Design robust data, retrieval, and search architecture first.</li>
        <li>Implement AI systems, SEO foundations, and visibility fixes with validation.</li>
        <li>Ship practical systems teams can adopt in daily workflows.</li>
      </ul>
      <p style="margin-top: 1rem;"><a href="/services/seo-geo-implementation">See how I implement SEO and GEO foundations</a></p>
    </aside>
  </section>

  <section class="section" id="services">
    <div class="section-header">
      <p class="kicker">What I Build</p>
      <h2>AI systems focused on automation, extraction, and knowledge access</h2>
    </div>
    <div class="grid">
      {services.map((service) => (
        <article class="card reveal">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          {service.href && <p style="margin-top: 0.9rem;"><a href={service.href}>Learn more</a></p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="problems">
    <div class="section-header">
      <p class="kicker">Problems I Solve</p>
      <h2>From manual bottlenecks to scalable AI workflows</h2>
    </div>
    <div class="grid">
      {problemsSolved.map((problem) => (
        <article class="card reveal">
          <h3>{problem.title}</h3>
          <p>{problem.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="featured-projects">
    <div class="section-header">
      <p class="kicker">Featured Projects</p>
      <h2>Selected AI automation, PDF extraction, and RAG systems</h2>
    </div>
    <div class="grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p style="margin-top: 1rem;"><a href="/projects">See all project details and architecture highlights</a></p>
  </section>

  <section class="section" id="bhiwandi-services">
    <div class="section-header">
      <p class="kicker">In Bhiwandi</p>
      <h2>Location-specific AI service pages for Bhiwandi businesses</h2>
    </div>
    <div class="grid">
      <article class="card reveal">
        <h3>RAG chatbot developer in Bhiwandi</h3>
        <p>
          A focused page on retrieval-augmented chatbots for SaaS knowledge bases, internal search, and support workflows.
        </p>
        <p style="margin-top: 0.9rem;"><a href="/bhiwandi/rag-systems">Explore RAG chatbot development in Bhiwandi</a></p>
      </article>
      <article class="card reveal">
        <h3>AI chatbot developer in Bhiwandi</h3>
        <p>
          A focused page on AI chatbot development in Bhiwandi for customer support, internal assistants, and retrieval-backed workflows.
        </p>
        <p style="margin-top: 0.9rem;"><a href="/bhiwandi/ai-chatbot-developer">Explore AI chatbot development in Bhiwandi</a></p>
      </article>
      <article class="card reveal">
        <h3>Workflow automation developer in Bhiwandi</h3>
        <p>
          A focused page on LLM workflow automation, operational routing, and business process design for teams that need usable automation.
        </p>
        <p style="margin-top: 0.9rem;"><a href="/bhiwandi/workflow-automation-developer">Explore workflow automation in Bhiwandi</a></p>
      </article>
      <article class="card reveal">
        <h3>Document workflow automation in Bhiwandi</h3>
        <p>
          A focused page on document-heavy workflows, PDF extraction, validation, and structured handoff into business systems.
        </p>
        <p style="margin-top: 0.9rem;"><a href="/bhiwandi/document-workflow-automation">Explore document workflow automation in Bhiwandi</a></p>
      </article>
      <article class="card reveal">
        <h3>SEO and GEO implementation</h3>
        <p>
          A focused page on technical SEO, local SEO, schema, indexing, and AI-search visibility improvements for service businesses.
        </p>
        <p style="margin-top: 0.9rem;"><a href="/services/seo-geo-implementation">Explore SEO and GEO implementation</a></p>
      </article>
    </div>
  </section>

  <section class="section" id="articles">
    <div class="section-header">
      <p class="kicker">Articles / Insights</p>
      <h2>Implementation notes from real AI engineering workflows</h2>
    </div>
    <div class="grid">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
    <p style="margin-top: 1rem;"><a href="/articles">Browse all AI engineering articles</a></p>
  </section>

  <section class="section" id="about-preview">
    <div class="section-header">
      <p class="kicker">About</p>
      <h2>Technical focus and problem-solving approach</h2>
    </div>
    <article class="card reveal">
      <p>
        I build implementation-focused systems across AI automation, document intelligence, RAG chatbots, and technical search
        foundations. That includes workflows that reduce manual work, document pipelines that produce usable data, and SEO / GEO
        improvements that make service businesses easier to discover in Google and AI-assisted search.
      </p>
      <p style="margin-top: 0.9rem;">
        Based in Bhiwandi, Maharashtra, India, I work on systems that need clear data flow, strong retrieval, practical
        implementation, and clean machine-readable structure from metadata through schema and internal linking.
      </p>
      <p style="margin-top: 0.9rem;"><a href="/about">Read my full background and technical approach</a></p>
      <p><a href="/services/seo-geo-implementation">Read about SEO and GEO implementation</a></p>
    </article>
  </section>

  <FAQ />

  <section class="section" id="contact">
    <div class="section-header">
      <p class="kicker">Contact</p>
      <h2>Let’s discuss your automation, document, or visibility problem</h2>
    </div>
    <article class="card reveal">
      <p>Email: <a href={siteConfig.email}>{siteConfig.emailLabel}</a></p>
      <p>GitHub: <a href={siteConfig.github}>{siteConfig.githubLabel}</a></p>
      <p>LinkedIn: <a href={siteConfig.linkedin}>{siteConfig.linkedinLabel}</a></p>
      <p>Instagram: <a href={siteConfig.instagram}>{siteConfig.instagramLabel}</a></p>
      <p>Portfolio: <a href={siteConfig.siteUrl}>{siteConfig.siteUrl}</a></p>
      <p><a href="/services/seo-geo-implementation">SEO and GEO implementation</a></p>
    </article>
  </section>
</BaseLayout>
